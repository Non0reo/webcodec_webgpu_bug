{
  "compilerOptions": {
    "target": "es2025",
    "module": "esnext",
    "lib": ["ES2025", "ESNext", "ESNext.SharedMemory"],
    "types": ["vite/client", "@types/wicg-file-system-access", "@types/web"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
